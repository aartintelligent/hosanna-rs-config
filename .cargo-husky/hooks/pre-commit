#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
#  hosanna-rs-config — pre-commit hook
#
#  Installed automatically by `cargo-husky` on the first `cargo test`.
#  Runs the same gates that CI runs, so a green commit is a green pipeline.
#
#  To bypass (emergency only):   git commit --no-verify
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

# ── Colour helpers (no-op when stdout is not a TTY) ─────────────────────────
if [[ -t 1 ]]; then
    readonly BOLD=$'\033[1m'
    readonly DIM=$'\033[2m'
    readonly GREEN=$'\033[32m'
    readonly RED=$'\033[31m'
    readonly RESET=$'\033[0m'
else
    readonly BOLD='' DIM='' GREEN='' RED='' RESET=''
fi

step() { printf '%s▸%s %s%s%s\n' "$BOLD" "$RESET" "$BOLD" "$1" "$RESET"; }
ok()   { printf '  %s✓ %s%s\n'  "$GREEN" "$1" "$RESET"; }
fail() { printf '  %s✗ %s%s\n'  "$RED"   "$1" "$RESET" >&2; }

on_failure() {
    fail "pre-commit blocked the commit — fix the step above and re-stage."
    printf '%s  bypass with: git commit --no-verify%s\n' "$DIM" "$RESET" >&2
}
trap on_failure ERR

# ── Gates ───────────────────────────────────────────────────────────────────

step "rustfmt — checking formatting"
cargo fmt --all -- --check
ok "formatting clean"

step "clippy — linting with -D warnings (all targets)"
cargo clippy --all-targets --locked -- -D warnings
ok "no clippy warnings"

step "cargo test — default features"
cargo test --locked
ok "default test suite passes"

step "cargo doc — rustdoc with -D warnings"
RUSTDOCFLAGS="-D warnings" cargo doc --no-deps --locked
ok "rustdoc clean"

printf '\n%s✓ pre-commit clean — good to go.%s\n' "$GREEN$BOLD" "$RESET"
